    "scripts": {
        "start": "node server/server.js",
        "build": "npm run build:prod",
        "db": "startDB.bat",
        "build:dev": "webpack --config-node-env development",
        "build:prod": "webpack --config-node-env production",
        "server": "nodemon --exec node --env-file=server/config/dev.env server/server.js -e js,html,css,scss",
